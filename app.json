{
  "expo": {
    "name": "女装库存管理",
    "slug": "ClothSaleApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clothsaleapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#ec407a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.runa.clothsale",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "需要访问相册以上传商品图片",
        "NSCameraUsageDescription": "需要访问相机以拍摄商品图片"
      },
      "buildNumber": "7",
      "appleTeamId": "Y5SP92H4XE"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ec407a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.runa.clothsale"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "需要访问相册以上传商品图片",
          "cameraPermission": "需要访问相机以拍摄商品图片"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#ec407a",
          "enableFullScreenImage_legacy": true
        }
      ],
      "./plugins/withFullscreenSplash",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/93f30720-ebe8-41e8-bdb1-a0544b2153b4"
    },
    "runtimeVersion": "carl-production-8",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93f30720-ebe8-41e8-bdb1-a0544b2153b4"
      }
    },
    "owner": "rockylc"
  }
}
